.claude/scheduled_tasks.lock
.claude/scheduled_tasks/
phase3-walk/

# ─── Local working notes / agent scratch ───
working/

# ─── Precedent research screenshots (third-party, copyrighted) ───
# Collected for the model-viewer rendering-style research. Keep local in this
# PUBLIC repo; never commit. Written analysis lives in the research doc that
# references these by filename.
planning/refactor/**/assets/precedent/

# ─── Licensed project models (real .hbjson) — never commit to this PUBLIC repo ───
# Real project geometry is licensed PH data. Keep it locally and point tests at
# it via PHN_HILLANDALE_FIXTURE; the synthetic ph_nav_v2_example.hbjson stays
# tracked. (The 49MB Hillandale fixture was purged from history 2026-06-30.)
**/Hillandale_*.hbjson

# Climate reference example data (Phius/PHI source files) — gitignored
# wherever the climate feature folder lives (active or archived).
**/climate/example_data/
# Licensed PHI/Phius climate SOURCE data must never be committed to this
# PUBLIC repo (it is licensed reference data — use only in-app). Local dev
# keeps untracked copies under backend/seeds/climate/; seeding pulls from the
# private object store. See planning/archive/climate-reference-data-seeding/.
backend/seeds/climate/**/*.txt
backend/seeds/climate/**/*.xlsx
backend/seeds/climate/**/*.json

# ─── Graphify output ───
graphify-out/

# === backend/.env.example ===
# Copy to backend/.env and fill in real values.
# Generate secrets with:
#   openssl rand -hex 32
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Auth
SESSION_LIFETIME_MINUTES=60
SESSION_COOKIE_NAME=phn_session
SESSION_COOKIE_SAMESITE=lax
PASSWORD_ARGON2_TIME_COST=3
PASSWORD_ARGON2_MEMORY_COST=65536
PASSWORD_ARGON2_PARALLELISM=4

# Database (local Docker Postgres)
POSTGRES_DB=ph_navigator_v2
POSTGRES_USER=phn
POSTGRES_PASSWORD=phn_local_only
POSTGRES_PORT=5433
DATABASE_URL=postgresql://phn:phn_local_only@localhost:5433/ph_navigator_v2
DATABASE_POOL_MIN_SIZE=2
DATABASE_POOL_MAX_SIZE=10
DATABASE_POOL_TIMEOUT_SECONDS=10
SLOW_QUERY_MS=500
PROJECT_DOCUMENT_MAX_BODY_BYTES=8388608

# Object storage (Cloudflare R2 in deployment; local MinIO via `make dev`)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=phn_minio
R2_SECRET_ACCESS_KEY=phn_minio_local_only
R2_BUCKET=ph-navigator-v2-dev
R2_ENDPOINT_URL=http://localhost:9000

# Crypto (for any at-rest field encryption)
FERNET_SECRET_KEY=replace_me_with_fernet_generate_key

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# MCP resource-server metadata
MCP_ISSUER_URL=http://localhost:8000
MCP_RESOURCE_SERVER_URL=http://localhost:8000/mcp
MCP_ENABLE_DNS_REBINDING_PROTECTION=true
# Extra comma-separated Host header values for deployed MCP endpoints.
# Defaults are derived from MCP_* URLs and CORS_ORIGINS; set this when
# Render/custom domains differ from those URLs.
MCP_ALLOWED_HOSTS=
# Extra comma-separated browser Origin values for MCP clients.
# Defaults are derived from MCP_* URLs and CORS_ORIGINS.
MCP_ALLOWED_ORIGINS=

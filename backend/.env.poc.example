# Catalog POC environment (PRD §13, plan §3.1).
# Copy this file to backend/.env.poc and fill in real credentials.
# .env.poc is gitignored. Load it explicitly when running the POC, e.g.:
#   set -a && source .env.poc && set +a && uvicorn main:app --reload

# Reuse the existing PHN settings from .env (JWT secret, Fernet key, etc.) by
# loading .env.poc *after* .env, or by copying needed values here.

CATALOG_POC_ENABLED=true

# Second Postgres database on the same local Docker instance. Use the same
# POSTGRES_USER / POSTGRES_PASSWORD as backend/.env (the docker-compose db
# service uses a non-default user). Run scripts/create_poc_db.sh to create.
CATALOG_POC_DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/ph_navigator_catalog_poc

# Cloudflare R2 — POC bucket only. Token must be scoped to ph-data-poc.
CATALOG_POC_R2_ACCOUNT_ID=
CATALOG_POC_R2_ACCESS_KEY_ID=
CATALOG_POC_R2_SECRET_ACCESS_KEY=
CATALOG_POC_R2_BUCKET=ph-data-poc

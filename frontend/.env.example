# === frontend/.env.example ===
# Copy to frontend/.env.local and adjust if the local API uses another port.
# Development browser requests remain same-origin through Vite's /api proxy.

VITE_API_PROXY_TARGET=http://localhost:8000

# Production builds may set VITE_API_BASE_URL to a separate API origin.
# VITE_API_BASE_URL=https://api.example.com
